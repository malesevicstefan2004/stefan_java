<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="apps.goal.InputController">
	<center>
		<HBox alignment="CENTER" spacing="50.0"
			BorderPane.alignment="CENTER">
			<children>
				<VBox alignment="CENTER" spacing="25.0"
					style="-fx-background-color: #1E90FF;">
					<children>
						<TextField fx:id="nameOfTeamA"
							promptText="Name of Team 1" />
						<Label fx:id="goalsOfTeamA" text="0" textFill="WHITE">
							<font>
								<Font name="System Bold" size="40.0" />
							</font>
						</Label>
						<Button mnemonicParsing="false"
							onAction="#increaseGoalsOfTeamA" text="Goal" />
					</children>
					<padding>
						<Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
					</padding>
				</VBox>
				<VBox alignment="CENTER" spacing="25.0"
					style="-fx-background-color: #FF3E96;">
					<children>
						<TextField fx:id="nameOfTeamB"
							promptText="Name of Team 2" />
						<Label fx:id="goalsOfTeamB" text="0" textFill="WHITE">
							<font>
								<Font name="System Bold" size="40.0" />
							</font>
						</Label>
						<Button mnemonicParsing="false"
							onAction="#increaseGoalsOfTeamB" text="Goal" />
					</children>
					<padding>
						<Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
					</padding>
				</VBox>
			</children>
		</HBox>
	</center>
	<bottom>
		<HBox alignment="CENTER" BorderPane.alignment="CENTER">
			<children>
				<Button mnemonicParsing="false" text="Finish"
					onAction="#goToOutputView" />
			</children>
			<padding>
				<Insets top="25.0" />
			</padding>
		</HBox>
	</bottom>
	<padding>
		<Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
	</padding>
</BorderPane>
